.health-root {
    width: 100%;
    height: 100%;
    padding-top: 20px;
    padding-left: 20px;
    justify-content: flex-start;
    align-items: flex-start;
}

.health-container {
    flex-direction: row;
    align-items: center;
}

.health-icon {
    width: 36px;
    height: 36px;
    margin-right: 8px;
    background-image: url("../../Sprites/UI/HealthUI.png");
    background-repeat: no-repeat;
    background-position: center;
    -unity-background-scale-mode: scale-to-fit;
}